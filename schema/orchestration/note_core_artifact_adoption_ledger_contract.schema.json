{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lonewolf.note_core.artifact_adoption_ledger_contract.v1",
  "$comment": "BUILD_ID: 2026-06-26_note_core_artifact_adoption_ledger_contract_v1",
  "title": "NOTE-Core Artifact Adoption Ledger Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "build_id",
    "record_type",
    "lane_name",
    "lane_status",
    "closeout_classification",
    "owner_acceptance_phrase",
    "source_artifact",
    "previous_contract",
    "recommended_next_action",
    "safety_boundary",
    "human_decision_point",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "note_core_artifact_adoption_ledger.v1"
    },
    "build_id": {
      "type": "string",
      "const": "2026-06-26_note_core_artifact_adoption_ledger_contract_v1"
    },
    "record_type": {
      "type": "string",
      "const": "note_core_artifact_adoption_ledger"
    },
    "lane_name": {
      "type": "string",
      "minLength": 1
    },
    "lane_status": {
      "type": "string",
      "minLength": 1
    },
    "closeout_classification": {
      "type": "string",
      "minLength": 1
    },
    "owner_acceptance_phrase": {
      "type": "string",
      "minLength": 1
    },
    "source_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "filename",
        "sha256",
        "artifact_type"
      ],
      "properties": {
        "filename": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "artifact_type": {
          "type": "string",
          "enum": [
            "note_scout",
            "note_review",
            "codex_packet",
            "closeout_packet"
          ]
        }
      }
    },
    "previous_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "lane",
        "status"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "lane": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "recommended_next_action": {
      "type": "string",
      "minLength": 1
    },
    "safety_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_touched",
        "deploy_touched",
        "api_touched",
        "auth_touched",
        "billing_touched",
        "trading_touched",
        "private_repo_read",
        "contracts_repo_read"
      ],
      "properties": {
        "runtime_touched": { "type": "boolean", "const": false },
        "deploy_touched": { "type": "boolean", "const": false },
        "api_touched": { "type": "boolean", "const": false },
        "auth_touched": { "type": "boolean", "const": false },
        "billing_touched": { "type": "boolean", "const": false },
        "trading_touched": { "type": "boolean", "const": false },
        "private_repo_read": { "type": "boolean", "const": false },
        "contracts_repo_read": { "type": "boolean", "const": false }
      }
    },
    "human_decision_point": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
