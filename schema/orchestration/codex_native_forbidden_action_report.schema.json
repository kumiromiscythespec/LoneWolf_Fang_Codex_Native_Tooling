{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/orchestration/codex_native_forbidden_action_report.schema.json",
  "$comment": "BUILD_ID: 20260613_codex_native_automation_gate_contracts_v1",
  "title": "Codex Native Forbidden Action Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "build_id",
    "report_id",
    "task_id",
    "attempted_action",
    "source_context",
    "redaction_status",
    "detected_at",
    "stop_reason",
    "owner_review_required",
    "execution_allowed",
    "runtime_allowed",
    "automatic_continuation_allowed",
    "expected_result",
    "human_review_one_point"
  ],
  "properties": {
    "schema": { "type": "string", "const": "lonewolf.codex_native.forbidden_action_report.v1" },
    "build_id": { "type": "string", "const": "20260613_codex_native_automation_gate_contracts_v1" },
    "report_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "attempted_action": { "$ref": "#/$defs/forbidden_action" },
    "source_context": { "type": "string", "minLength": 1 },
    "redaction_status": {
      "type": "string",
      "enum": ["synthetic_fixture", "redacted_by_reference"]
    },
    "detected_at": { "type": "string", "minLength": 1 },
    "stop_reason": { "type": "string", "minLength": 1 },
    "owner_review_required": { "type": "boolean", "const": true },
    "execution_allowed": { "type": "boolean", "const": false },
    "runtime_allowed": { "type": "boolean", "const": false },
    "automatic_continuation_allowed": { "type": "boolean", "const": false },
    "expected_result": { "type": "string", "const": "STOP_OWNER_REVIEW_REQUIRED" },
    "human_review_one_point": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "forbidden_action": {
      "type": "string",
      "enum": [
        "runtime_attempt",
        "deploy_attempt",
        "private_openai_api_attempt",
        "cloud_mutation_attempt",
        "billing_mutation_attempt",
        "trading_order_attempt",
        "automatic_continuation_attempt",
        "unknown_state_gate_action",
        "forbidden_action_attempt"
      ]
    }
  }
}
