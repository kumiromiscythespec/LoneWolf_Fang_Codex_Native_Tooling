      "type": "object",
      "additionalProperties": false,
      "required": [
        "queue_handoff_evidence_only",
        "owner_review_required",
        "ready_is_go",
        "observed_safe_no_action_is_go",
        "automatic_go_allowed",
        "execution_allowed",
        "queue_mutation_allowed",
        "worker_launch_allowed"
