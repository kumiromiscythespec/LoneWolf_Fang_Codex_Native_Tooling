        "wildcard_scope_used": { "type": "boolean", "const": false },
        "directory_only_scope_used": { "type": "boolean", "const": false },
        "broad_fixture_directory_used": { "type": "boolean", "const": false },
        "outside_docs_schema_tests_fixtures": { "type": "boolean", "const": false },
        "runtime_source_cloud_billing_trading_paths_in_scope": { "type": "boolean", "const": false }
      }
