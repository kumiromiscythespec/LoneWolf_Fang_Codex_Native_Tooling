      "properties": {
        "artifact_chain_role": { "type": "string", "const": "request_intake_approval_binding_evidence_chain" },
        "implementation_approval_packet_path": { "type": "string", "minLength": 1 },
        "implementation_approval_packet_sha256": { "$ref": "#/$defs/sha256" },
        "planning_integration_packet_path": { "type": "string", "minLength": 1 },
        "planning_integration_packet_sha256": { "$ref": "#/$defs/sha256" },
        "stable_closeout_packet_path": { "type": "string", "minLength": 1 },
        "stable_closeout_packet_sha256": { "$ref": "#/$defs/sha256" },
        "implementation_evidence_required": { "type": "boolean", "const": true }
      }
    },
    "blocker_matrix": {
      "type": "array",
      "items": { "$ref": "#/$defs/blocker" }
    },
    "blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "blocker_id",
        "severity",
        "reason",
        "evidence_reference",
        "fail_closed_action",
        "owner_review_required",
        "allows_progression"
