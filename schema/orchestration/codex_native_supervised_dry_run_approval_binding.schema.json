        "implementation_approval_packet_path",
        "implementation_approval_packet_sha256",
        "planning_integration_packet_path",
        "planning_integration_packet_sha256",
        "stable_closeout_packet_path",
        "stable_closeout_packet_sha256",
        "implementation_evidence_required"
