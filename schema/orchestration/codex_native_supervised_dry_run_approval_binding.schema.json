  "$comment": "BUILD_ID: 20260614_request_intake_approval_binding_contracts_v1",
  "build_id": "20260614_request_intake_approval_binding_contracts_v1",
  "title": "Codex Native Supervised Dry-Run Approval Binding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "build_id",
    "approval_binding_id",
    "request_id",
    "requested_target",
    "exact_owner_approval_phrase",
