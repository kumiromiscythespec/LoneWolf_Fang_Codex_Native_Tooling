      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_intake_schema",
        "request_intake_decision",
        "request_intake_build_id",
        "request_intake_artifact_required"
      ],
      "properties": {
        "request_intake_schema": { "type": "string", "const": "lonewolf.codex_native.supervised_dry_run_request_intake.v1" },
        "request_intake_decision": { "type": "string", "enum": ["READY_FOR_REQUEST_INTAKE_REVIEW", "STOP_OWNER_REVIEW_REQUIRED"] },
        "request_intake_build_id": { "type": "string", "const": "20260614_request_intake_approval_binding_contracts_v1" },
        "request_intake_artifact_required": { "type": "boolean", "const": true }
      }
    },
    "artifact_chain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
