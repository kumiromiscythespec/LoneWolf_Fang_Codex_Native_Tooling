        "receipt_presence_is_execution_approval": { "const": false },
        "ready_is_go": { "const": false },
        "matched_is_go": { "const": false },
        "observed_safe_no_action_is_go": { "const": false },
        "request_draft_ready_is_go": { "const": false },
        "preflight_bound_ready_is_go": { "const": false },
        "automatic_go_allowed": { "const": false },
        "implementation_allowed": { "const": false },
        "commit_allowed": { "const": false },
        "push_allowed": { "const": false },
        "runtime_execution_allowed": { "const": false },
        "worker_launch_allowed": { "const": false },
        "queue_mutation_allowed": { "const": false },
