      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_execution_performed",
        "runtime_allowed",
        "worker_launch_performed",
        "queue_mutation_performed",
        "cloud_api_mutation_performed",
        "private_openai_api_performed",
        "billing_auth_mutation_performed",
        "trading_or_order_performed",
        "deploy_performed",
        "commit_performed",
