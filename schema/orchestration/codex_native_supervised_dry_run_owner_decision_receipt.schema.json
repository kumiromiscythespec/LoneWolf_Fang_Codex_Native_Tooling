      "properties": {
        "runtime_execution_performed": { "const": false },
        "runtime_allowed": { "const": false },
        "worker_launch_performed": { "const": false },
        "queue_mutation_performed": { "const": false },
        "cloud_api_mutation_performed": { "const": false },
        "private_openai_api_performed": { "const": false },
        "billing_auth_mutation_performed": { "const": false },
        "trading_or_order_performed": { "const": false },
        "deploy_performed": { "const": false },
        "commit_performed": { "const": false },
        "push_performed": { "const": false },
        "fetch_pull_performed": { "const": false },
        "cleanup_performed": { "const": false },
        "automatic_continuation_performed": { "const": false }
      }
