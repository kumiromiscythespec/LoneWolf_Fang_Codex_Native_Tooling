{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/orchestration/codex_native_owner_approval_record.schema.json",
  "$comment": "BUILD_ID: 20260613_codex_native_automation_gate_contracts_v1",
  "build_id": "20260613_codex_native_automation_gate_contracts_v1",
  "title": "Codex Native Owner Approval Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "build_id",
    "approval_id",
    "approval_created_at_utc",
    "approval_expires_at_utc",
    "task_id",
    "target_repo",
    "branch",
    "head",
    "local_origin_master",
    "stable_baseline",
    "artifact_chain_id",
    "artifact_sha256",
    "approval_phrase",
    "action_class",
    "approved_file_allowlist",
    "approved_command_allowlist",
    "safety_boundary_version",
    "owner_approval_required",
    "execution_allowed",
    "runtime_allowed",
    "automatic_continuation_allowed",
    "mutation_approval_single_use",
    "stale_if_any_bound_field_differs",
    "ambiguity_result",
    "reuse_prohibitions",
    "supersession_status",
    "expected_result",
    "human_review_one_point"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "lonewolf.codex_native.owner_approval_record.v1"
    },
    "build_id": {
      "type": "string",
      "const": "20260613_codex_native_automation_gate_contracts_v1"
    },
    "approval_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "approval_created_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "approval_expires_at_utc": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "target_repo": {
      "type": "string",
      "minLength": 1
    },
    "branch": {
      "type": "string",
      "minLength": 1
    },
    "head": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{40}$"
    },
    "local_origin_master": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{40}$"
    },
    "stable_baseline": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{40}$"
    },
    "artifact_chain_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "approval_phrase": {
      "type": "string",
      "minLength": 1
    },
    "action_class": {
      "type": "string",
      "enum": [
        "POLICY_INPUT",
        "DOCS_SCHEMA_TESTS_FIXTURES_IMPLEMENTATION"
      ]
    },
    "approved_file_allowlist": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "approved_command_allowlist": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "safety_boundary_version": {
      "type": "string",
      "minLength": 1
    },
    "owner_approval_required": {
      "type": "boolean",
      "const": true
    },
    "execution_allowed": {
      "type": "boolean",
      "const": false
    },
    "runtime_allowed": {
      "type": "boolean",
      "const": false
    },
    "automatic_continuation_allowed": {
      "type": "boolean",
      "const": false
    },
    "mutation_approval_single_use": {
      "type": "boolean",
      "const": true
    },
    "stale_if_any_bound_field_differs": {
      "type": "boolean",
      "const": true
    },
    "ambiguity_result": {
      "type": "string",
      "const": "STOP_OWNER_REVIEW_REQUIRED"
    },
    "reuse_prohibitions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commit",
        "push",
        "runtime",
        "deploy",
        "api",
        "cloud",
        "billing",
        "trading",
        "daemon_watcher",
        "ui_automation",
        "automatic_continuation",
        "cleanup_or_history_rewrite"
      ],
      "properties": {
        "commit": { "type": "boolean", "const": true },
        "push": { "type": "boolean", "const": true },
        "runtime": { "type": "boolean", "const": true },
        "deploy": { "type": "boolean", "const": true },
        "api": { "type": "boolean", "const": true },
        "cloud": { "type": "boolean", "const": true },
        "billing": { "type": "boolean", "const": true },
        "trading": { "type": "boolean", "const": true },
        "daemon_watcher": { "type": "boolean", "const": true },
        "ui_automation": { "type": "boolean", "const": true },
        "automatic_continuation": { "type": "boolean", "const": true },
        "cleanup_or_history_rewrite": { "type": "boolean", "const": true }
      }
    },
    "supersession_status": {
      "type": "string",
      "enum": ["ACTIVE", "SUPERSEDED", "STALE", "BLOCKED"]
    },
    "expected_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_review_required",
        "execution_allowed",
        "runtime_allowed",
        "automatic_continuation_allowed",
        "next_action_recommendation"
      ],
      "properties": {
        "owner_review_required": { "type": "boolean", "const": true },
        "execution_allowed": { "type": "boolean", "const": false },
        "runtime_allowed": { "type": "boolean", "const": false },
        "automatic_continuation_allowed": { "type": "boolean", "const": false },
        "next_action_recommendation": { "type": "string", "minLength": 1 }
      }
    },
    "human_review_one_point": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  }
}
