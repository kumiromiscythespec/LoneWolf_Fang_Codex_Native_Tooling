{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/orchestration/file_queue_linkage_ledger_entry.schema.json",
  "$comment": "BUILD_ID: 20260612_fasttrack_window2_linkage_ledger_writer_schema_v0",
  "title": "File Queue Linkage Ledger Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "build_id",
    "proof_id",
    "chain_id",
    "task_id",
    "current_state",
    "ledger_path",
    "overwrite_existing",
    "created_at",
    "proof_summary",
    "evidence_references",
    "safety_summary",
    "forbidden_actions_confirmation"
  ],
  "properties": {
    "schema": { "type": "string", "const": "lonewolf.file_queue.linkage_ledger_entry.v1" },
    "build_id": { "type": "string", "const": "20260612_fasttrack_window2_linkage_ledger_writer_fixture_v0" },
    "writer_build_id": { "type": "string", "const": "20260612_fasttrack_window2_linkage_ledger_writer_v0" },
    "proof_id": { "type": "string", "pattern": "^[A-Za-z0-9_.:-]+$" },
    "chain_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "current_state": { "$ref": "#/$defs/linkage_state" },
    "ledger_path": { "type": "string", "minLength": 1 },
    "overwrite_existing": { "type": "boolean", "const": false },
    "created_at": { "type": "string", "format": "date-time" },
    "ledger_recorded_at": { "type": "string", "format": "date-time" },
    "proof_summary": { "type": "string", "minLength": 1 },
    "proof_payload_sha256": { "$ref": "#/$defs/sha256" },
    "ledger_record_sha256": { "$ref": "#/$defs/sha256" },
    "checksum_algorithm": { "type": "string", "const": "SHA256" },
    "evidence_references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "path", "sha256"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "task_result_linkage",
              "linkage_state",
              "owner_decision",
              "execution_result",
              "output_packet",
              "test_summary",
              "artifact_manifest"
            ]
          },
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "$ref": "#/$defs/sha256" },
          "notes": { "type": "string", "minLength": 1 }
        }
      }
    },
    "safety_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_only",
        "appdata_only",
        "evidence_by_reference",
        "no_secrets",
        "no_network",
        "no_task_execution",
        "no_queue_consumption",
        "no_daemon_watcher"
      ],
      "properties": {
        "local_only": { "type": "boolean", "const": true },
        "appdata_only": { "type": "boolean", "const": true },
        "evidence_by_reference": { "type": "boolean", "const": true },
        "no_secrets": { "type": "boolean", "const": true },
        "no_network": { "type": "boolean", "const": true },
        "no_task_execution": { "type": "boolean", "const": true },
        "no_queue_consumption": { "type": "boolean", "const": true },
        "no_daemon_watcher": { "type": "boolean", "const": true }
      }
    },
    "forbidden_actions_confirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["forbidden_actions_performed", "confirmed_absent"],
      "properties": {
        "forbidden_actions_performed": { "type": "boolean", "const": false },
        "confirmed_absent": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "linkage_state": {
      "type": "string",
      "enum": [
        "AUTHORED",
        "VALIDATED_DRY_RUN",
        "EXECUTION_APPROVED",
        "EXECUTED_APPDATA_ONLY",
        "BLOCKED",
        "FAILED_SAFE",
        "STOP_OWNER_REVIEW_REQUIRED",
        "SUPERSEDED",
        "ARCHIVED"
      ]
    }
  }
}
