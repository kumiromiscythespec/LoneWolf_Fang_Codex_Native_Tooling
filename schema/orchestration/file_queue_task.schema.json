{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/orchestration/file_queue_task.schema.json",
  "$comment": "BUILD_ID: 20260612_file_queue_task_schema_v1",
  "title": "File Queue Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "task_id",
    "title",
    "target_repo",
    "mode",
    "allowed_files",
    "forbidden_actions",
    "success_criteria",
    "stop_conditions",
    "owner_approval_phrase",
    "artifact_requirements",
    "expected_final_report_labels"
  ],
  "properties": {
    "schema": { "type": "string", "const": "lonewolf.file_queue.task.v1" },
    "build_id": { "type": "string", "const": "20260612_file_queue_fixture_v1" },
    "task_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "target_repo": { "type": "string", "minLength": 1 },
    "mode": {
      "type": "string",
      "enum": [
        "docs_only",
        "schema_tests_only",
        "static_validation_only",
        "artifact_handoff_only"
      ]
    },
    "allowed_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "forbidden_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/forbidden_action" },
      "minItems": 16,
      "uniqueItems": true,
      "allOf": [
        { "contains": { "const": "worker_launch" } },
        { "contains": { "const": "real_orchestration" } },
        { "contains": { "const": "browser_ui_automation" } },
        { "contains": { "const": "chatgpt_ui_automation" } },
        { "contains": { "const": "codex_ui_automation" } },
        { "contains": { "const": "runtime_execution" } },
        { "contains": { "const": "deploy" } },
        { "contains": { "const": "paper_live_order" } },
        { "contains": { "const": "cancel_order" } },
        { "contains": { "const": "fetch_balance" } },
        { "contains": { "const": "private_api" } },
        { "contains": { "const": "provider_mutation" } },
        { "contains": { "const": "billing_mutation" } },
        { "contains": { "const": "secrets_output" } },
        { "contains": { "const": "reset_restore_clean" } },
        { "contains": { "const": "force_push" } }
      ]
    },
    "success_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "stop_conditions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "owner_approval_phrase": { "type": "string", "minLength": 1 },
    "artifact_requirements": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "expected_final_report_labels": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    }
  },
  "$defs": {
    "forbidden_action": {
      "type": "string",
      "enum": [
        "worker_launch",
        "real_orchestration",
        "browser_ui_automation",
        "chatgpt_ui_automation",
        "codex_ui_automation",
        "runtime_execution",
        "deploy",
        "paper_live_order",
        "cancel_order",
        "fetch_balance",
        "private_api",
        "provider_mutation",
        "billing_mutation",
        "secrets_output",
        "reset_restore_clean",
        "force_push"
      ]
    }
  }
}
