{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/codex_native_closed_loop/state_gate_names.schema.json",
  "$comment": "BUILD_ID: 20260613_codex_native_automation_gate_contracts_v1",
  "title": "Codex Native State Gate Names",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "build_id",
    "states",
    "events",
    "guards",
    "next_actions",
    "unknown_name_policy"
  ],
  "properties": {
    "schema": { "type": "string", "const": "lonewolf.codex_native.state_gate_names.v1" },
    "build_id": { "type": "string", "const": "20260613_codex_native_automation_gate_contracts_v1" },
    "states": {
      "type": "array",
      "items": { "$ref": "#/$defs/state_name" },
      "uniqueItems": true
    },
    "events": {
      "type": "array",
      "items": { "$ref": "#/$defs/event_name" },
      "uniqueItems": true
    },
    "guards": {
      "type": "array",
      "items": { "$ref": "#/$defs/guard_name" },
      "uniqueItems": true
    },
    "next_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/next_action_name" },
      "uniqueItems": true
    },
    "unknown_name_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_review_required",
        "execution_allowed",
        "runtime_allowed",
        "automatic_continuation_allowed",
        "default_next_action"
      ],
      "properties": {
        "owner_review_required": { "type": "boolean", "const": true },
        "execution_allowed": { "type": "boolean", "const": false },
        "runtime_allowed": { "type": "boolean", "const": false },
        "automatic_continuation_allowed": { "type": "boolean", "const": false },
        "default_next_action": { "type": "string", "const": "REQUIRE_OWNER_REVIEW" }
      }
    }
  },
  "$defs": {
    "state_name": {
      "type": "string",
      "enum": [
        "PAUSED_BASELINE_ACCEPTED",
        "PLANNING_ONLY",
        "APPROVAL_PACKET_READY",
        "STATIC_IMPLEMENTATION_READY",
        "LOCAL_COMMIT_READY",
        "PUSH_READY",
        "MANUAL_LOOP_READY",
        "SUPERVISED_DRY_RUN_READY",
        "SUPERVISED_DRY_RUN_RUNNING",
        "OWNER_REVIEW_REQUIRED",
        "FAIL_CLOSED",
        "RUNTIME_PROHIBITED",
        "DEPLOY_PROHIBITED",
        "API_PROHIBITED",
        "TRADING_PROHIBITED"
      ]
    },
    "event_name": {
      "type": "string",
      "enum": [
        "OWNER_APPROVAL",
        "PACKET_CREATED",
        "TEST_PASS",
        "TEST_FAIL",
        "UNEXPECTED_DIRTY_WORKTREE",
        "MISSING_ARTIFACT",
        "CHECKSUM_MISMATCH",
        "AMBIGUOUS_STATE",
        "FORBIDDEN_ACTION_ATTEMPT",
        "AUTOMATION_PROMOTION_REQUEST",
        "STALE_OWNER_APPROVAL",
        "UNKNOWN_NAME"
      ]
    },
    "guard_name": {
      "type": "string",
      "enum": [
        "exact_sha_match",
        "local_origin_master_matches_head",
        "ahead_behind_zero",
        "clean_worktree",
        "staged_file_count_zero",
        "known_branch_head",
        "input_artifact_checksum_match",
        "manifest_schema_exact",
        "required_packet_entries_present",
        "no_forbidden_action",
        "owner_approval_phrase_exact",
        "all_static_tests_pass",
        "rollback_available",
        "no_runtime_mutation",
        "build_id_marker_present",
        "allowlist_path_only"
      ]
    },
    "next_action_name": {
      "type": "string",
      "enum": [
        "CREATE_APPROVAL_PACKET_ONLY",
        "INCLUDE_IN_NEXT_WAVE_IMPLEMENTATION_APPROVAL_INTEGRATION_PACKET",
        "REQUIRE_OWNER_REVIEW",
        "PREPARE_STATIC_DOCS_SCHEMA_TESTS_FIXTURES_ONLY",
        "RUN_STATIC_TESTS_ONLY",
        "PREPARE_LOCAL_COMMIT_ONLY",
        "PREPARE_PUSH_ONLY",
        "MANUAL_LOOP_REVIEW_ONLY",
        "CONSIDER_SUPERVISED_DRY_RUN_ONLY",
        "START_SUPERVISED_DRY_RUN_ONLY",
        "STOP_FAIL_CLOSED",
        "STOP_RUNTIME_PROHIBITED",
        "STOP_DEPLOY_PROHIBITED",
        "STOP_API_PROHIBITED",
        "STOP_TRADING_PROHIBITED"
      ]
    }
  }
}
